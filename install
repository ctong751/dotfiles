#!/bin/bash
set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BACKUP_DIR="$HOME/.dotfiles-backup/$(date +%Y%m%d-%H%M%S)"
backed_up=false

# Colors & symbols
if [[ -t 1 ]]; then
    bold='\033[1m'
    dim='\033[2m'
    green='\033[32m'
    yellow='\033[33m'
    red='\033[31m'
    reset='\033[0m'
else
    bold='' dim='' green='' yellow='' red='' reset=''
fi

# Buffered output — collects items per section, prints one line when flushed
_section="" _items=""
section() {
    flush
    _section="$1"
    _items=""
}
ok()   { [[ -n "$_items" ]] && _items+=", "; _items+="$1"; }
warn() { printf "  ${yellow}⚠ %-10s${reset} %s\n" "$_section" "$1"; }
err()  { printf "  ${red}✗ %-10s${reset} %s\n" "$_section" "$1"; }
info() { printf "  ${dim}  %-10s %s${reset}\n" "" "$1"; }
flush() {
    [[ -z "$_section" ]] && return
    printf "  ${green}✓${reset} ${bold}%-10s${reset} ${dim}%s${reset}\n" "$_section" "$_items"
}

pkg_install() {
    local pkg="$1"
    if command -v brew &>/dev/null; then
        brew install "$pkg"
    elif command -v apt &>/dev/null; then
        sudo apt install -y "$pkg"
    else
        err "no package manager found (need brew or apt)"
        return 1
    fi
}

ensure() {
    local cmd="$1"
    local pkg="${2:-$1}"
    if ! command -v "$cmd" &>/dev/null; then
        pkg_install "$pkg"
    fi
}

backup() {
    local target="$1"
    if [[ -e "$target" && ! -L "$target" ]]; then
        if [[ "$backed_up" == false ]]; then
            mkdir -p "$BACKUP_DIR"
            backed_up=true
        fi
        cp -r "$target" "$BACKUP_DIR/"
    fi
}

link() {
    local src="$1"
    local dst="$2"
    backup "$dst"
    rm -rf "$dst"
    ln -s "$src" "$dst"
    ok "$(basename "$dst")"
}

printf "\n${bold}  dotfiles${reset} ${dim}— installing into %s${reset}\n\n" "$HOME"

# Neovim
section "nvim"
ensure nvim neovim
ensure fd
ensure rg ripgrep
mkdir -p "$HOME/.config"
link "$BASEDIR/nvim" "$HOME/.config/nvim"

# Git
section "git"
ensure lazygit
link "$BASEDIR/git/gitconfig" "$HOME/.gitconfig"
link "$BASEDIR/git/gitignore" "$HOME/.gitignore"

# Ghostty
section "ghostty"
if [[ "$(uname)" == "Darwin" ]]; then
    ghostty_dir="$HOME/Library/Application Support/com.mitchellh.ghostty"
else
    ghostty_dir="$HOME/.config/ghostty"
fi
mkdir -p "$ghostty_dir"
link "$BASEDIR/ghostty/config" "$ghostty_dir/config"
if command -v brew &>/dev/null; then
    brew list --cask font-jetbrains-mono &>/dev/null || brew install --cask font-jetbrains-mono
    ok "JetBrains Mono"
fi

# Zsh
section "zsh"
if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
    RUNZSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    ok "oh-my-zsh"
else
    ok "oh-my-zsh (exists)"
fi
ensure powerlevel10k
ensure zsh-autosuggestions
link "$BASEDIR/zsh/zshrc" "$HOME/.zshrc"
link "$BASEDIR/zsh/p10k.zsh" "$HOME/.p10k.zsh"

# Tmux
section "tmux"
ensure tmux
[[ "$(uname)" == "Linux" ]] && ensure playerctl
link "$BASEDIR/tmux" "$HOME/.config/tmux"

# ccstatusline
section "ccstatusline"
mkdir -p "$HOME/.config/ccstatusline"
link "$BASEDIR/ccstatusline/settings.json" "$HOME/.config/ccstatusline/settings.json"
link "$BASEDIR/ccstatusline/run" "$HOME/.config/ccstatusline/run"

# Claude Code
section "claude"
mkdir -p "$HOME/.claude"
claude_settings="$HOME/.claude/settings.json"
statusline_cmd="$HOME/.config/ccstatusline/run"
claude_settings_existed=0
[[ -e "$claude_settings" || -L "$claude_settings" ]] && claude_settings_existed=1
if [[ -L "$claude_settings" ]]; then
    tmp_settings="$(mktemp)"
    if [[ -e "$claude_settings" ]]; then
        cat "$claude_settings" > "$tmp_settings"
    else
        printf '{}\n' > "$tmp_settings"
    fi
    rm "$claude_settings"
    mv "$tmp_settings" "$claude_settings"
fi
if command -v python3 &>/dev/null; then
    CLAUDE_SETTINGS="$claude_settings" DOTFILES_CLAUDE_SETTINGS="$BASEDIR/claude/settings.json" STATUSLINE_CMD="$statusline_cmd" python3 - <<'PY'
import json
import os
from pathlib import Path

settings_path = Path(os.environ["CLAUDE_SETTINGS"])
dotfiles_path = Path(os.environ["DOTFILES_CLAUDE_SETTINGS"])
statusline_cmd = os.environ["STATUSLINE_CMD"]

existing = {}
if settings_path.exists():
    with settings_path.open() as f:
        existing = json.load(f)

with dotfiles_path.open() as f:
    dotfiles = json.load(f)

merged = dict(existing)
for key, value in dotfiles.items():
    if isinstance(value, dict) and isinstance(existing.get(key), dict):
        nested = dict(existing[key])
        nested.update(value)
        merged[key] = nested
    else:
        merged[key] = value

merged.setdefault("statusLine", {})["command"] = statusline_cmd

with settings_path.open("w") as f:
    json.dump(merged, f, indent=2)
    f.write("\n")
PY
    if [[ "$claude_settings_existed" == "1" ]]; then
        ok "settings.json (merged)"
    else
        ok "settings.json"
    fi
else
    if [[ -f "$claude_settings" ]]; then
        warn "python3 not found, skipping settings merge"
    else
        printf '{\n  "statusLine": {\n    "type": "command",\n    "command": "%s",\n    "padding": 0\n  }\n}\n' "$statusline_cmd" > "$claude_settings"
        ok "settings.json"
    fi
fi
link "$BASEDIR/claude/CLAUDE.md" "$HOME/.claude/CLAUDE.md"

# Pi / agent skills + extensions
section "pi"
mkdir -p "$HOME/.agents/skills" "$HOME/.pi/agent/skills" "$HOME/.pi/agent/extensions"
pi_settings="$HOME/.pi/agent/settings.json"
if command -v python3 &>/dev/null; then
    PI_SETTINGS="$pi_settings" DOTFILES_PI_SETTINGS="$BASEDIR/pi/settings.json" python3 - <<'PY'
import json
import os
from pathlib import Path


def merge(existing, dotfiles):
    if isinstance(existing, dict) and isinstance(dotfiles, dict):
        merged = dict(existing)
        for key, value in dotfiles.items():
            if key in merged:
                merged[key] = merge(merged[key], value)
            else:
                merged[key] = value
        return merged

    if isinstance(existing, list) and isinstance(dotfiles, list):
        merged = []
        seen = set()
        for item in [*existing, *dotfiles]:
            marker = json.dumps(item, sort_keys=True)
            if marker in seen:
                continue
            seen.add(marker)
            merged.append(item)
        return merged

    return dotfiles


settings_path = Path(os.environ["PI_SETTINGS"])
dotfiles_path = Path(os.environ["DOTFILES_PI_SETTINGS"])

existing = {}
if settings_path.exists():
    with settings_path.open() as f:
        existing = json.load(f)

with dotfiles_path.open() as f:
    dotfiles = json.load(f)

merged = merge(existing, dotfiles)

with settings_path.open("w") as f:
    json.dump(merged, f, indent=2)
    f.write("\n")
PY
    ok "settings.json"
else
    if [[ -f "$pi_settings" ]]; then
        warn "python3 not found, skipping settings merge"
    else
        cp "$BASEDIR/pi/settings.json" "$pi_settings"
        ok "settings.json"
    fi
fi
backup "$HOME/.pi/agent/extensions/diff.ts"
rm -rf "$HOME/.pi/agent/extensions/diff.ts"
link "$BASEDIR/agents/skills/git-commit-safety" "$HOME/.agents/skills/git-commit-safety"
link "$HOME/.agents/skills/git-commit-safety" "$HOME/.pi/agent/skills/git-commit-safety"
if compgen -G "$BASEDIR/pi/extensions/*.ts" > /dev/null; then
    for extension_src in "$BASEDIR"/pi/extensions/*.ts; do
        link "$extension_src" "$HOME/.pi/agent/extensions/$(basename "$extension_src")"
    done
else
    warn "no Pi extensions found in $BASEDIR/pi/extensions"
fi
if [[ "${INSTALL_AGENT_SKILLS:-0}" == "1" ]]; then
    if command -v npx &>/dev/null; then
        "$BASEDIR/scripts/install-agent-skills"
        ok "third-party skills"
    else
        warn "npx not found, skipping third-party skill install"
    fi
else
    info "set INSTALL_AGENT_SKILLS=1 to install third-party skills via skills.sh"
fi

# Hotkeys (Linux + GNOME only)
if [[ "$(uname)" == "Linux" ]] && command -v gsettings &>/dev/null; then
    section "hotkeys"
    ensure wmctrl
    ensure xdotool
    mkdir -p "$HOME/.config/hotkeys"
    link "$BASEDIR/hotkeys/focus-or-open" "$HOME/.config/hotkeys/focus-or-open"
    "$BASEDIR/hotkeys/setup-gnome-keybindings.sh"
fi

# Keyboard (Linux only — remap Caps Lock to Control)
if [[ "$(uname)" == "Linux" && -f /etc/default/keyboard ]]; then
    section "keyboard"
    if ! grep -q 'ctrl:nocaps' /etc/default/keyboard; then
        sudo cp "$BASEDIR/keyboard/keyboard" /etc/default/keyboard
        ok "caps lock → control"
        info "reboot or run 'sudo dpkg-reconfigure keyboard-configuration' to apply"
    else
        ok "ctrl:nocaps"
    fi
fi

flush
printf "\n${bold}${green}  ✓ done${reset}"
if [[ "$backed_up" == true ]]; then
    printf " ${dim}(backups in $BACKUP_DIR)${reset}"
fi
printf "\n\n"
